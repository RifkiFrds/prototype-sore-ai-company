# =============================================
# Docker Compose Environment Variables
# Salin file ini menjadi .env sebelum menjalankan docker-compose
# =============================================

# AI Provider (Sumopod)
SUMOPOD_API_KEY="your-sumopod-api-key-here"
SUMOPOD_BASE_URL="https://ai.sumopod.com"
SUMOPOD_MODEL="deepseek-v4-flash"

# Discord Bot
DISCORD_TOKEN="your-discord-bot-token-here"
DISCORD_CLIENT_ID="your-discord-client-id-here"

# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/prototipe_sore?schema=public"
